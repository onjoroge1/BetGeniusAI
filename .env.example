# BetGenius AI Backend - Environment Variables
# Copy this file to .env and fill in your actual API keys

# RapidAPI Football API Key
# Get from: https://rapidapi.com/api-sports/api/api-football/
RAPIDAPI_KEY=your_rapidapi_key_here

# OpenAI API Key for GPT-4o analysis
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# BetGenius API Key for securing endpoints
# Generate a secure random string for production
BETGENIUS_API_KEY=betgenius_secure_key_2024_change_this

# Optional: Customize model behavior
MODEL_CONFIDENCE_THRESHOLD=0.7
OPENAI_TEMPERATURE=0.3
MAX_REQUESTS_PER_MINUTE=60

# Development settings
LOG_LEVEL=INFO
CACHE_TTL=300
